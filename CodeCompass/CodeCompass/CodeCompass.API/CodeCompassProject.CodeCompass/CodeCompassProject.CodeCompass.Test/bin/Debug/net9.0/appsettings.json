{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CodeCompassProject": "Debug"
    }
  },
  "AllowedHosts": "*",
  "AwsBedrock": {
    "Region": "eu-central-1",
    "ModelId": "amazon.titan-embed-text-v2:0",
    "ChatModelId": "anthropic.claude-3-haiku-20240307-v1:0",
    "EmbeddingDimension": 1024
  },
  "OpenSearch": {
    "Endpoint": "http://localhost:9200",
    "IndexName": "codecompass-index",
    "Region": "ap-southeast-2",
    "BatchSize": 100
  },
  "Chunking": {
    "MaxTokens": 512,
    "MinTokens": 50,
    "OverlapTokens": 50
  },
  "Ingestion": {
    "ConcurrencyLevel": 4,
    "EmbeddingBatchSize": 16,
    "MaxFileSizeMB": 50
  },
  "KnowledgeBases": {
    "Product": {
      "SourcePathPrefix": "Solvas_AM_Classic_Product_Knowledge_Base"
    },
    "TechStack": {
      "SourcePathPrefix": "Solvas_AM_Modern_Platform_Tech_Stack_Knowledge_Base"
    }
  }
